{
  "name": "mail-service",
  "version": "1.0.0",
  "description": "API para enviar correos electrónicos con Gmail y plantillas HTML",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node dist/server.js",
    "build": "esbuild src/server.js --bundle --platform=node --format=esm --outfile=dist/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-handlebars": "^7.1.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.8",
    "nodemailer-express-handlebars": "^6.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
