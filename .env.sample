# Copia este archivo a .env y ajusta valores
API_KEY=pon-tu-api-key-segura-aqui

# Configuración de Gmail (recomendado usar App Password)
GMAIL_USER=tu_email@gmail.com
GMAIL_PASS=tu_app_password_de_gmail

# Datos por defecto del remitente
MAIL_FROM_NAME=Tu Servicio
MAIL_FROM_EMAIL=tu_email@gmail.com

# Servidor
PORT=3000
