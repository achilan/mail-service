# Copia este archivo a .env y ajusta valores
API_KEY=pon-tu-api-key-segura-aqui

# Configuración SMTP (ejemplo Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true            # true = puerto 465 (SSL) | false = puerto 587 (STARTTLS)
SMTP_USER=tucorreo@tudominio.com
SMTP_PASS=la_contraseña_del_buzón

# Datos por defecto del remitente
MAIL_FROM_NAME=Tu Servicio
MAIL_FROM_EMAIL=tucorreo@tudominio.com

# Servidor
PORT=3000
